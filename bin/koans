#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "rbconfig"
require "English"

module RubyKoansCLI
  ROOT = File.expand_path("..", __dir__)
  SRC_DIR = File.join(ROOT, "src")
  KOANS_DIR = File.join(ROOT, "koans")
  PATH_FILE = "path_to_enlightenment.rb"
  DEFAULT_PROGRESS_FILE = File.join(KOANS_DIR, ".path_progress")

  class << self
    def call(argv)
      command = argv.shift || "walk"

      case command
      when "walk", "run", "meditate"
        exit walk
      when "watch"
        exit watch
      when "list"
        exit list
      when "next"
        exit next_step
      when "hint"
        exit hint
      when "reset"
        exit reset(argv)
      when "help", "--help", "-h"
        puts help_text
        exit 0
      else
        warn "Unknown koan command: #{command}"
        warn
        warn help_text
        exit 1
      end
    end

    def walk
      return 1 unless generate_koans

      run([ruby, PATH_FILE], KOANS_DIR)
    end

    def watch
      return 1 unless generate_koans

      puts "The Sensei is watching the path. Press Ctrl-C when meditation is done."
      last_signature = nil

      trap("INT") do
        puts
        puts "The Master bows. Return when you are ready."
        exit 0
      end

      loop do
        signature = watched_files_signature
        if signature != last_signature
          clear_screen
          walk_without_regenerating
          last_signature = signature
        end
        sleep watch_interval
      end
    end

    def list
      steps = koan_steps
      progress = progress_count
      groups = group_steps_by_file(steps)

      puts "The path currently winds through #{groups.size} gates."
      puts "Progress remembered by the Sensei: #{[progress, steps.size].min}/#{steps.size} steps."
      puts

      groups.each_with_index do |group, index|
        status = group_status(group, progress)
        count = group[:steps].size
        puts format("%2d. %-28s %-9s %2d steps  koans/%s", index + 1, group[:class_name], status, count, group[:file])
      end

      0
    end

    def next_step
      step = current_step
      if step
        puts "The next stone on the path:"
        puts "  #{step_label(step)}"
        puts "  #{step_location(step)}"
        puts
        puts "Run `bin/koans hint` if you need a nudge, not an answer."
      else
        puts "Mountains are again merely mountains. The path is complete."
      end
      0
    end

    def hint
      step = current_step
      unless step
        puts "Mountains are again merely mountains. No hint is needed."
        return 0
      end

      hint_lines = hint_lines_for(step)

      puts "A whisper from the Master:"
      puts "  #{step_label(step)}"
      puts
      if hint_lines.empty?
        puts "  Read the assertion slowly. The expected shape is already in the test."
      else
        hint_lines.each { |line| puts "  #{line}" }
      end
      puts
      puts "No answers. Only direction."
      0
    end

    def reset(argv)
      target = argv.shift
      unless target
        warn "Usage: bin/koans reset <about_file|all>"
        return 1
      end

      if target == "all"
        return run(["rake", "regen"], ROOT)
      end

      file = normalize_target_file(target)
      source = File.join(SRC_DIR, file)
      destination = File.join(KOANS_DIR, file)

      unless File.file?(source)
        warn "No such koan source: src/#{file}"
        return 1
      end

      FileUtils.mkdir_p(KOANS_DIR)
      make_koan_file(source, destination)
      puts "The stone has been returned to its uncarved form: koans/#{file}"
      0
    rescue ArgumentError => error
      warn error.message
      1
    end

    def generate_koans
      run(["rake", "gen"], ROOT).zero?
    end

    def walk_without_regenerating
      run([ruby, PATH_FILE], KOANS_DIR)
    end

    def run(command, directory)
      Dir.chdir(directory) do
        system(*command)
      end
      status = $CHILD_STATUS
      status && status.exitstatus ? status.exitstatus : 1
    end

    def ruby
      RbConfig.ruby
    end

    def watch_interval
      Float(ENV.fetch("KOANS_WATCH_INTERVAL", "0.5"))
    rescue ArgumentError
      0.5
    end

    def clear_screen
      system("clear") if $stdout.tty? && !ENV["KOANS_NO_CLEAR"]
    end

    def watched_files_signature
      Dir[File.join(KOANS_DIR, "*.{rb,txt}")].sort.map do |file|
        stat = File.stat(file)
        [file, stat.mtime.to_f, stat.size]
      end
    end

    def current_step
      koan_steps[progress_count]
    end

    def progress_file
      ENV.fetch("KOANS_PROGRESS_FILE", DEFAULT_PROGRESS_FILE)
    end

    def progress_count
      return 0 unless File.file?(progress_file)

      File.read(progress_file).to_s.gsub(/\s/, "").split(",").last.to_i
    end

    def koan_steps
      @koan_steps ||= begin
        load_koan_definitions
        ordered_koans.flat_map do |koan_class, file|
          koan_class.testmethods.map do |method_name|
            {
              class_name: koan_class.name,
              file: file,
              method_name: method_name.to_s
            }
          end
        end
      end
    end

    def load_koan_definitions
      ENV["NEO_DISABLE_END"] = "true"
      $LOAD_PATH.unshift(SRC_DIR) unless $LOAD_PATH.include?(SRC_DIR)
      Dir.chdir(SRC_DIR) do
        load File.join(SRC_DIR, PATH_FILE)
      end
    end

    def ordered_koans
      available = Neo::Koan.subclasses

      require_order.flat_map do |required_file|
        file = "#{required_file}.rb"
        available.select { |klass| koan_source_file(klass) == file }.map { |klass| [klass, file] }
      end
    end

    def require_order
      File.read(File.join(SRC_DIR, PATH_FILE)).scan(/^\s*require ['"]([^'"]+)['"]/).flatten
    end

    def koan_source_file(koan_class)
      method_name = koan_class.testmethods.first
      return nil unless method_name

      location = koan_class.instance_method(method_name).source_location
      location && File.basename(location.first)
    end

    def group_steps_by_file(steps)
      groups = []
      steps.each_with_index do |step, index|
        group = groups.find { |candidate| candidate[:file] == step[:file] }
        unless group
          group = {
            class_name: step[:class_name],
            file: step[:file],
            first_step: index + 1,
            steps: []
          }
          groups << group
        end
        group[:steps] << step
      end
      groups
    end

    def group_status(group, progress)
      first = group[:first_step]
      last = first + group[:steps].size - 1

      if progress >= last
        "opened"
      elsif progress >= first - 1
        "next"
      else
        "waiting"
      end
    end

    def step_label(step)
      "#{step[:class_name]}##{step[:method_name]}"
    end

    def step_location(step)
      line = method_line(File.join(KOANS_DIR, step[:file]), step[:method_name]) ||
        method_line(File.join(SRC_DIR, step[:file]), step[:method_name])
      location = "koans/#{step[:file]}"
      line ? "#{location}:#{line}" : location
    end

    def method_line(file, method_name)
      return nil unless File.file?(file)

      File.readlines(file).each_with_index do |line, index|
        return index + 1 if line =~ /^\s*def\s+#{Regexp.quote(method_name)}\b/
      end
      nil
    end

    def hint_lines_for(step)
      file = File.join(SRC_DIR, step[:file])
      lines = File.readlines(file)
      index = lines.find_index { |line| line =~ /^\s*def\s+#{Regexp.quote(step[:method_name])}\b/ }
      return [] unless index

      cursor = index - 1
      cursor -= 1 while cursor >= 0 && lines[cursor].strip.empty?

      comments = []
      while cursor >= 0 && lines[cursor] =~ /^\s*#(.*)$/
        text = Regexp.last_match(1).strip
        comments << text unless ["--", "++"].include?(text)
        cursor -= 1
      end

      comments.reverse
    end

    def normalize_target_file(target)
      file = target.sub(%r{\A(?:src|koans)/}, "")
      file = "#{file}.rb" if File.extname(file).empty?
      unless file =~ /\A[\w.\-]+\z/
        raise ArgumentError, "Unsafe koan file name: #{target}"
      end
      file
    end

    def make_koan_file(source, destination)
      if File.basename(source) =~ /neo/
        FileUtils.cp(source, destination)
        return
      end

      File.open(source) do |input|
        File.open(destination, "w") do |output|
          state = :copy
          input.each do |line|
            state = :skip if line =~ /^ *#--/
            output.puts remove_solution(line) if state == :copy
            state = :copy if line =~ /^ *#\+\+/
          end
        end
      end
    end

    def remove_solution(line)
      line = line.gsub(/\b____\([^\)]+\)/, "____")
      line = line.gsub(/\b___\([^\)]+\)/, "___")
      line = line.gsub(/\b__\([^\)]+\)/, "__")
      line = line.gsub(/\b_n_\([^\)]+\)/, "_n_")
      line = line.gsub(%r(/\#\{__\}/), "/__/")
      line.gsub(/\s*#\s*__\s*$/, "")
    end

    def help_text
      <<~TEXT
        Ruby Koans

        Usage: bin/koans <command>

        Commands:
          walk       Generate koans if needed, then walk the path
          watch      Re-run the path whenever a koan file changes
          list       Show the gates on the path and remembered progress
          next       Show the next koan remembered by the Sensei
          hint       Show a nudge for the next koan, without the answer
          reset FILE Return one koan file to its unanswered form
          reset all  Regenerate the full koans directory; removes your answers
          help       Show this help

        The classic `rake` flow still works.
      TEXT
    end
  end
end

RubyKoansCLI.call(ARGV)
